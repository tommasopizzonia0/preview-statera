RESEND_API_KEY=re_xxxxxxxxx
# Dopo aver verificato un dominio su Resend:
# RESEND_FROM_EMAIL=Statera <contatti@tuodominio.it>

# Meta Pixel: ID del dataset (Events Manager -> Origini dei dati).
# NEXT_PUBLIC_ = viene inlinato nel bundle client al momento della build.
NEXT_PUBLIC_META_PIXEL_ID=0000000000000000
# Token della Conversions API (Events Manager -> Impostazioni -> API Conversions).
# Segreto: solo server, mai committarlo.
META_CAPI_ACCESS_TOKEN=EAAxxxxxxxxx
